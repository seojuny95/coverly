OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# pgvector
DATABASE_URL=postgresql://postgres:password@localhost:5432/coverly
REFERENCE_DATA_DATABASE_ENABLED=true
RAG_PG_TABLE=official_rag_chunks
RAG_EMBEDDING_DIM=1536
POLICY_RAG_TTL_SECONDS=900
POLICY_RAG_MAX_TTL_SECONDS=7200
POLICY_RAG_SESSION_SECRET=replace-with-random-secret

# PDF parsing capacity
PDF_PARSING_MAX_CONCURRENCY=2
PDF_PARSING_MAX_QUEUE_SIZE=8
PDF_PARSING_QUEUE_TIMEOUT_SECONDS=60
PDF_PARSING_RETRY_AFTER_SECONDS=5
